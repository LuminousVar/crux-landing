# ── Public values ────────────────────────────────────────────────────────────
# Anything prefixed PUBLIC_ is INLINED INTO THE BROWSER BUNDLE by Vite at build time and
# is readable by every visitor at /_app/env.js. Only put values here that are meant to be
# public. NEVER an API key: it does not matter where the value is stored — a .env file,
# the Vercel dashboard, a secret manager — the PUBLIC_ prefix is what ships it to the
# client.

# Formspree form endpoint for the "Suggest a Feature" card.
# Sign up at https://formspree.io, create a form, and paste the endpoint here.
PUBLIC_FORMSPREE_URL=https://formspree.io/f/YOUR_FORM_ID


# ── Server-only values ───────────────────────────────────────────────────────
# Read exclusively by the Vercel Function in api/chat.js. No PUBLIC_ prefix, so they never
# reach the browser. Set these in the Vercel dashboard for the deployed site.

# Groq API key for the landing-page chat assistant. This was PUBLIC_LLM_API_KEY until it
# turned out that served the key to every visitor in plain text.
GROQ_API_KEY=gsk_your_key_here

# Optional — override the provider or model. Any OpenAI-compatible endpoint works.
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
